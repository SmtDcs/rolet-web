# Copy this to apps/web/.env.local and fill in your own RPC key.

# L1 Solana RPC (devnet) — Get your RPC Fast endpoint at https://rpcfast.com for the Hackathon Track
NEXT_PUBLIC_RPC_ENDPOINT=https://devnet.rpcfast.com/?api-key=YOUR_RPCFAST_KEY
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Deployed ROLET program (devnet)
NEXT_PUBLIC_ROLET_PROGRAM_ID=2ePEUzCFcxD559Hy3irB2TGbYAwU2UD352sVj77QPrS7

# MagicBlock ER endpoint (currently routed to but not delegated to)
NEXT_PUBLIC_MAGICBLOCK_ER_ENDPOINT=https://devnet.magicblock.app
