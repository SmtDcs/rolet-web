# Copy this to apps/web/.env.local and fill in your own RPC key.

# Frontend RPC — uses our /api/rpc proxy to avoid CORS issues with RPC Fast
NEXT_PUBLIC_RPC_ENDPOINT=/api/rpc
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Server-side: the real RPC Fast Beam endpoint (proxied by /api/rpc)
# Get your key at https://rpcfast.com
RPCFAST_BACKEND_URL=https://beam.rpcfast.com/?api-key=YOUR_RPCFAST_KEY

# Deployed ROLET program (devnet)
NEXT_PUBLIC_ROLET_PROGRAM_ID=2ePEUzCFcxD559Hy3irB2TGbYAwU2UD352sVj77QPrS7

# MagicBlock ER endpoint (currently routed to but not delegated to)
NEXT_PUBLIC_MAGICBLOCK_ER_ENDPOINT=https://devnet.magicblock.app
