{
  "name": "@rolet/server",
  "version": "1.0.0",
  "scripts": {
    "dev": "echo '(rolet/server is now an Anchor workspace — use pnpm anchor:build / anchor:deploy / anchor:localnet)' && exit 0",
    "anchor:build": "anchor build --no-idl",
    "anchor:deploy": "anchor deploy",
    "anchor:test": "anchor test --skip-local-validator",
    "anchor:localnet": "solana-test-validator --reset",
    "build": "anchor build --no-idl",
    "start": "echo '(no node entrypoint — program lives in target/deploy/rolet.so)' && exit 0"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@rolet/shared": "workspace:*",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "license": "ISC"
}
